    "@shipflow/inngest": "workspace:*",
    "@shipflow/logger": "workspace:*",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.33.0",
    "inngest": "^3.27.0",
    "razorpay": "^2.9.4",
